  "breakingChangeProtocol": {
    "step1": "New behavior → add NEW endpoint (`/v2/...`) alongside old",
    "step2": "Keep old endpoint working for 6 months",
    "step3": "Update SDK integration guides with migration path",
    "step4": "Announce in changelog: 'old endpoint deprecated DATE, removed DATE+6mo'",
    "step5": "After 6 months: remove old endpoint + delete tests"
  },
  "validationRules": {
    "headers": {
      "x_shre_tenant": {
        "required": true,
        "description": "Identifies tenant/merchant",
        "enforcedOn": ["POST /v1/events/batch", "GET /v1/sdk/config", "POST /v1/sdk/heartbeat", "POST /v1/sdk/session"]
      },
      "x_shre_app": {
        "required": true,
        "description": "Identifies app (rapid_pos, rapid_bos)",
        "enforcedOn": ["POST /v1/events/batch", "POST /v1/sdk/heartbeat"]
      },
      "Content_Type": {
        "required": true,
        "value": "application/json",
        "enforcedOn": ["POST /v1/events/batch", "POST /v1/sdk/session", "POST /v1/sdk/heartbeat"]
      },
      "Authorization": {
        "required": false,
        "description": "Bearer token for read_write mode",
        "format": "Bearer <jwt_token>"
      }
    },
    "responseCodes": {
      "200": "Success",
      "400": "Bad request (missing/invalid headers, malformed JSON)",
      "401": "Unauthorized (invalid token/bootstrap key)",
      "403": "Forbidden (tracking disabled)",
      "429": "Rate limited",
      "500": "Server error"
    },
    "eventIdempotency": {
      "required": true,
      "description": "Each event must have unique eventId for retry safety",
      "format": "UUID v4",
      "enforcedOn": ["POST /v1/events/batch"]
    },
    "contentType": {
      "required": true,
      "enforceJsonOnly": true,
      "description": "Never return HTML on error"
    }
  }
}
